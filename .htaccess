# Datei: /radio-app/.htaccess

# Verhindert den Zugriff auf .env (Sicherheitsrelevante Zugangsdaten)
<Files .env>
    Order allow,deny
    Deny from all
</Files>

# Verhindert das Auflisten von Ordnerinhalten (Directory Browsing)
# Dies sorgt dafür, dass Hacker nicht sehen können, welche Dateien im Ordner liegen
Options -Indexes

# Schützt .json Dateien vor direktem Aufruf über den Browser
# Nur die App/PHP soll darauf zugreifen können
<Files "*.json">
    Order allow,deny
    Deny from all
</Files>